# Application
APP_NAME="Campus Management Platform"
APP_ENV=development
APP_URL=http://localhost
APP_DEBUG=true
APP_SECRET_KEY=your-secret-key-here-change-in-production

# Database
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=campus_db
DB_USER=root
DB_PASS=

# Mail
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@campus.edu
MAIL_FROM_NAME="Campus Platform"

# Session
SESSION_LIFETIME=3600
SESSION_NAME=campus_session

# File Uploads
MAX_UPLOAD_SIZE=10485760
UPLOAD_PATH=uploads/
